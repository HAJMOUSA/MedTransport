# ─── MidTransport Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in all values before running docker-compose up

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=midtransport
POSTGRES_USER=midtransport
POSTGRES_PASSWORD=change_this_strong_password_1234
# Set to true only when connecting to a cloud DB (e.g. Supabase, RDS) that requires SSL
DATABASE_SSL=false

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password_5678

# ─── API Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Secret for signing JWTs — must be at least 32 random characters
JWT_SECRET=change_this_to_a_long_random_secret_string_here_minimum_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_for_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of the API as seen from the browser
VITE_API_URL=http://localhost:3001

# ─── Twilio (SMS — OTP + notifications) ─────────────────────────────────────
# Create free account at twilio.com — you get $15 free credit to start
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── SendGrid (Email notifications) ─────────────────────────────────────────
# Create free account at sendgrid.com — 100 emails/day free
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=MidTransport

# ─── App Settings ────────────────────────────────────────────────────────────
# Your organization name (shown in emails + SMS)
ORG_NAME=Your Transport Company
# Base URL for the web app (used in SMS/email links)
APP_BASE_URL=http://localhost:3000
# OTP expiry in seconds (default: 600 = 10 minutes)
OTP_EXPIRY_SECONDS=600
# Geofence radius in meters for auto-arrival detection
GEOFENCE_ARRIVAL_RADIUS_M=100
# GPS update interval in seconds for active drivers
GPS_UPDATE_INTERVAL_S=10
